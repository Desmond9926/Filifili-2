{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@filifili/api-kit": ["packages/api-kit/src"],
      "@filifili/api-kit/*": ["packages/api-kit/src/*"],
      "@filifili/types": ["packages/types/src"],
      "@filifili/types/*": ["packages/types/src/*"],
      "@filifili/db": ["packages/db/src"],
      "@filifili/db/*": ["packages/db/src/*"],
      "@filifili/worker": ["packages/worker/src"],
      "@filifili/worker/*": ["packages/worker/src/*"]
    }
  },
  "include": ["packages", "apps"]
}
