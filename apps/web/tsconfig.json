{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@filifili/api-kit": [
        "../../packages/api-kit/src"
      ],
      "@filifili/api-kit/*": [
        "../../packages/api-kit/src/*"
      ],
      "@filifili/db": [
        "../../packages/db/src"
      ],
      "@filifili/db/*": [
        "../../packages/db/src/*"
      ],
      "@filifili/types": [
        "../../packages/types/src"
      ],
      "@filifili/types/*": [
        "../../packages/types/src/*"
      ]
    },
    "types": [
      "node",
      "next"
    ],
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
