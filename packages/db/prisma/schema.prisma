generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  creator
  moderator
  admin
}

enum VideoStatus {
  draft
  uploading
  uploaded
  transcoding
  review_pending
  published
  rejected
  hidden
  deleted
}

enum CommentStatus {
  visible
  hidden
  deleted
}

enum ReportStatus {
  pending
  resolved
  rejected
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String    @unique
  passwordHash String
  role         Role      @default(user)
  disabledAt   DateTime?
  avatarUrl    String?
  bio          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  videos         Video[]
  comments       Comment[]
  likes          Like[]
  favorites      Favorite[]
  auditLogs      AuditLog[]
  reports        Report[]   @relation("ReportReporter")
  handledReports Report[]   @relation("ReportHandler")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos Video[]

  @@unique([name])
}

model Video {
  id              String      @id @default(uuid())
  title           String
  description     String
  authorId        String
  categoryId      String
  status          VideoStatus @default(draft)
  tags            String[]
  coverUrl        String?
  publishedAt     DateTime?
  durationSec     Int?
  width           Int?
  height          Int?
  likeCount       Int         @default(0)
  favoriteCount   Int         @default(0)
  commentCount    Int         @default(0)
  reviewNote      String?
  processingError String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  author    User        @relation(fields: [authorId], references: [id])
  category  Category    @relation(fields: [categoryId], references: [id])
  assets    VideoAsset?
  comments  Comment[]
  likes     Like[]
  favorites Favorite[]
  Report    Report[]

  @@index([status])
  @@index([categoryId, status])
}

model VideoAsset {
  id          String   @id @default(uuid())
  videoId     String   @unique
  originalUrl String?
  hlsUrl      String?
  coverUrl    String?
  durationSec Int?
  sizeBytes   Int?
  format      String?
  resolution  String?
  bitrate     Int?
  createdAt   DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id])
}

model Comment {
  id        String        @id @default(uuid())
  videoId   String
  userId    String
  parentId  String?
  content   String
  status    CommentStatus @default(visible)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  video   Video     @relation(fields: [videoId], references: [id])
  user    User      @relation(fields: [userId], references: [id])
  parent  Comment?  @relation("CommentToReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentToReplies")

  @@index([videoId, status])
}

model Like {
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@id([userId, videoId])
}

model Favorite {
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@id([userId, videoId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])
}

model Report {
  id         String       @id @default(uuid())
  videoId    String
  reporterId String
  reason     String
  status     ReportStatus @default(pending)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  handlerId  String?
  note       String?

  video    Video @relation(fields: [videoId], references: [id])
  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id])
  handler  User? @relation("ReportHandler", fields: [handlerId], references: [id])

  @@index([status])
}
