DATABASE_URL="postgresql://<db_user>:<db_password>@<db_host>:5432/filifili?schema=public"
REDIS_URL="redis://:<redis_password>@<redis_host>:6379/0"
# JWT
JWT_SECRET="<your_jwt_secret>"

# Qiniu Kodo placeholders
QINIU_ACCESS_KEY="<your_qiniu_access_key>"
QINIU_SECRET_KEY="<your_qiniu_secret_key>"
QINIU_BUCKET="<your_qiniu_bucket>"
QINIU_REGION="as0"
QINIU_UPLOAD_URL="https://upload-<region>.qiniup.com"
QINIU_SERVER_UPLOAD_URL="https://up-<region>.qiniup.com"
QINIU_PUBLIC_BASE_URL="https://<your-origin-domain>"
QINIU_USE_CDN="true"
CDN_BASE_URL="https://<your-cdn-domain>"
